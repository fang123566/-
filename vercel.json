{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    { "src": "/index.html", "dest": "/index.html" },
    { "src": "/(.+\.html)$", "dest": "/$1" },
    { "src": "/(.*)", "dest": "/$1" },
    { "src": "/(.*)$", "dest": "/index.html", "status": 404 }
  ]
}